# Anthropic API key — server-only, NEVER use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=sk-ant-...

# Sentry error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token

# Express backend URL (used by next.config rewrites server-side)
EXPRESS_URL=http://localhost:3001

# Public variables (exposed to browser)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------
# DŮLEŽITÉ: Express server (.env) musí mít nastavenou CORS_ORIGIN:
#   CORS_ORIGIN=http://localhost:3000
# Bez toho Express odmítne požadavky z Next.js dev serveru.
# ---------------------------------------------------------
