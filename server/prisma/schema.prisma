generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  username          String       @unique
  password          String
  role              String       @default("user") // user | moderator | admin
  status            String       @default("active") // active | suspended | banned
  avatarUrl         String?
  trustScore        Int          @default(0)
  totalSales        Int          @default(0)
  credits           Int          @default(3)
  verified          Boolean      @default(false)
  verifiedType      String?      @default("none")
  founder           Boolean      @default(false)
  founderSince      DateTime?
  vipUntil          DateTime?
  stripeCustomerId  String?      @unique
  lastDailyCredit   DateTime?
  acceptedTermsAt   DateTime?
  acceptedPrivacyAt DateTime?
  createdIp         String?
  userAgent         String?
  emailVerifiedAt   DateTime?
  emailVerifyToken  String?
  emailVerifyExpiresAt DateTime?
  passwordResetToken String?
  passwordResetExpires DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime     @default(now())
  auctions          Auction[]
  bids              Bid[]
  watchlists        Watchlist[]
  notifications     Notification[]
  transactions      Transaction[] @relation("BuyerTransactions")
  sales             Transaction[] @relation("SellerTransactions")
  referrals         Referral[]   @relation("Referrer")
  referred          Referral[]   @relation("Referred")
  wantedCards       WantedCard[]
  collection        CollectionItem[]
  collectionSnapshots CollectionValueSnapshot[]
  followers         Follow[]   @relation("Following")
  following         Follow[]   @relation("FollowedBy")
  reviewsGiven      Review[]   @relation("Reviewer")
  reviewsReceived   Review[]   @relation("Reviewed")
  subscriptions     Subscription[]
  promotions        Promotion[]
  reports           Report[]     @relation("Reporter")
  auditLogs         AuditLog[]
  adminNotes        AdminNote[]  @relation("AdminNoteAuthor")
  revokedTokens     RevokedToken[]
  uploads           Upload[]

  @@index([role])
  @@index([status])
  @@index([passwordResetToken])
  @@index([emailVerifyToken])
}

model Report {
  id          String   @id @default(cuid())
  auctionId   String
  reporterId  String
  reason      String   // fake | stolen_image | scam | inappropriate | suspicious_price | other
  description String?
  status      String   @default("pending") // pending | reviewed | resolved | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  auction     Auction  @relation(fields: [auctionId], references: [id])
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  @@index([status])
  @@index([auctionId])
  @@index([reporterId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  metadata    String?  // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model CardSet {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     String
  brand        String?
  year         String?
  description  String?
  imageUrl     String?
  totalCards   Int?

  // 🔒 Legal audit
  dataSource      String?
  licenseStatus   String?  @default("needs_review")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cards        DatabaseCard[]
}

model DatabaseCard {
  id                  String   @id @default(cuid())
  setId               String
  set                 CardSet  @relation(fields: [setId], references: [id], onDelete: Cascade)

  name                String
  slug                String   @unique
  cardNumber          String?
  playerName          String?
  team                String?
  rarity              String?
  parallel            String?
  type                String?
  imageUrl            String?
  description         String?

  cardmarketUrl       String?
  ebaySearchQuery     String?

  priceCardmarketLow  Float?
  priceCardmarketAvg  Float?
  priceCardmarketTrend Float?
  priceEbayAvg        Float?
  priceEbayMedian     Float?
  priceEbayLastSold   Float?

  currency            String?  @default("CZK")
  pricesUpdatedAt     DateTime?

  // 🔒 Legal audit – sledování původu dat
  dataSource          String?  // "limitlesstcg" | "pokemontcg_api" | "scryfall" | "ygoprodeck" | "user_uploaded" | "manual"
  sourceUrl           String?
  licenseStatus       String?  @default("needs_review") // own_data | user_uploaded | api_allowed | attribution_required | unknown | prohibited | needs_review

  // 🤖 AI data
  aiGenerated         Boolean? @default(false)
  aiConfidence        Float?
  aiModel             String?
  aiGeneratedAt       DateTime?
  manuallyVerified    Boolean? @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  priceSnapshots      CardPriceSnapshot[]

  @@index([setId])
  @@index([name])
  @@index([playerName])
  @@index([cardNumber])
  @@index([rarity])
}

model CardPriceSnapshot {
  id              String   @id @default(cuid())
  cardId          String
  card            DatabaseCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  source          String
  currency        String
  lowPrice        Float?
  avgPrice        Float?
  medianPrice     Float?
  trendPrice      Float?
  lastSoldPrice   Float?

  rawData         String?

  // 🔒 Legal audit
  dataSource      String?  // "cardmarket_api" | "ebay_api" | "cardbid_transactions" | "manual"
  licenseStatus   String?  @default("needs_review")

  createdAt       DateTime @default(now())

  @@index([cardId])
  @@index([source])
  @@index([createdAt])
}

// Card model pro aukce
model Card {
  id             String    @id @default(cuid())
  name           String
  setName        String
  setCode        String
  category       String    @default("pokemon")
  cardNumber     String?
  rarity         String?
  imageUrl       String?
  estimatedPrice Float?
  // 🔒 Legal audit
  status         String    @default("active") // active | archived | hidden
  dataSource     String?   // "manual" | "import" | "api" | "user"
  sourceUrl      String?
  licenseStatus  String?   @default("needs_review")
  // 🤖 AI data
  aiGenerated    Boolean?  @default(false)
  aiConfidence   Float?
  aiModel        String?
  aiGeneratedAt  DateTime?
  manuallyVerified Boolean? @default(false)
  // Relations
  auctions       Auction[]
}

model Auction {
  id            String     @id @default(cuid())
  title         String
  description   String?
  condition     String     @default("NM") // NM | LP | MP | HP | DMG
  imageUrl      String?
  startingPrice Float
  currentPrice  Float
  minIncrement  Float      @default(1)
  endTime       DateTime
  status        String     @default("ACTIVE") // draft | active | ended | cancelled | pending_review | removed
  featured      Boolean    @default(false)
  buyNowPrice   Float?
  buyNowUsed    Boolean    @default(false)
  // 🤖 AI risk assessment
  aiRiskScore   Float?
  aiRiskLevel   String?    // "low" | "medium" | "high" | "critical"
  aiRiskReason  String?
  // Admin review
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime   @default(now())
  userId        String
  cardId        String?
  user          User       @relation(fields: [userId], references: [id])
  card          Card?      @relation(fields: [cardId], references: [id])
  bids          Bid[]
  watchlists    Watchlist[]
  transaction   Transaction?
  promotions    Promotion[]
  reports       Report[]

  @@index([status])
  @@index([endTime])
  @@index([userId])
  @@index([status, endTime])
  @@index([status, createdAt])
  @@index([userId, status])
  @@index([featured])
  @@index([cardId])
  @@index([title])
  @@index([status, featured])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  maxBid    Float?
  createdAt DateTime @default(now())
  userId    String
  auctionId String
  user      User     @relation(fields: [userId], references: [id])
  auction   Auction  @relation(fields: [auctionId], references: [id])

  @@index([auctionId])
  @@index([userId])
  @@index([auctionId, amount])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  auction   Auction  @relation(fields: [auctionId], references: [id])
  @@unique([userId, auctionId])
  @@index([userId])
  @@index([auctionId])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([read])
}

model Transaction {
  id                   String         @id @default(cuid())
  amount               Float
  fee                  Float          @default(0)
  feePercent           Float          @default(0)
  netAmount            Float          @default(0)
  status               String         @default("PENDING")
  stripePaymentIntentId String?
  stripeSessionId      String?
  createdAt            DateTime       @default(now())
  auctionId            String         @unique
  buyerId              String
  sellerId             String
  auction              Auction        @relation(fields: [auctionId], references: [id])
  buyer                User           @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller               User           @relation("SellerTransactions", fields: [sellerId], references: [id])
  review               Review?
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
}

model Subscription {
  id            String   @id @default(cuid())
  plan          String   // "vip_monthly" | "vip_yearly"
  status        String   @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  stripePriceId String?
  stripeSubId   String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt     DateTime @default(now())
  cancelledAt   DateTime?
  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

model Promotion {
  id            String   @id @default(cuid())
  type          String   // "top" | "homepage" | "highlight" | "social"
  price         Float
  stripeSessionId String?
  status        String   @default("PENDING") // PENDING | ACTIVE | EXPIRED
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  auctionId     String
  auction       Auction  @relation(fields: [auctionId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

model MonetizationConfig {
  id            String   @id @default("platform")
  // Fee nastavení
  feePhase      String   @default("phase1") // phase1 | phase2
  feeDefault    Float    @default(0)
  feeBelow500   Float    @default(0)
  fee500to5000  Float    @default(5)
  feeAbove5000  Float    @default(6)
  feeFounder    Float    @default(3)
  feeVip        Float    @default(3)
  // Ceny v Kč
  verifiedPrice Float    @default(199)
  vipMonthly    Float    @default(199)
  vipYearly     Float    @default(1990)
  boostTop      Float    @default(19)
  boostHomepage Float    @default(49)
  boostHighlight Float   @default(15)
  boostSocial   Float    @default(99)
  // Founder limit
  founderLimit  Int      @default(20)
  founderCount  Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  transactionId String @unique
  reviewerId  String
  reviewedId  String
  transaction Transaction @relation(fields: [transactionId], references: [id])
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewed    User     @relation("Reviewed", fields: [reviewedId], references: [id])
}

model CollectionItem {
  id            String   @id @default(cuid())
  userId        String
  cardId        String
  cardName      String
  cardSet       String
  cardRarity    String?
  cardImage     String?
  quantity      Int      @default(1)
  purchasePrice Float?
  marketValue   Float?
  condition     String   @default("NM")
  notes         String?
  category      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())
  user          User     @relation(fields: [userId], references: [id])
  @@unique([userId, cardId])
  @@index([userId])
}

model CollectionValueSnapshot {
  id          String   @id @default(cuid())
  userId      String
  totalValue  Float
  totalCards  Int
  uniqueCards Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowedBy", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model WantedCard {
  id          String   @id @default(cuid())
  userId      String
  cardId      String
  cardName    String
  cardSet     String
  description String?
  maxPrice    Float?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@unique([userId, cardId])
  @@index([userId])
}

// ─── Admin modely ─────────────────────────────────────────────

model RevokedToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([jti])
  @@index([userId])
  @@index([expiresAt])
}

model AdminNote {
  id        String   @id @default(cuid())
  content   String
  entityType String  // "user" | "auction" | "report"
  entityId  String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("AdminNoteAuthor", fields: [authorId], references: [id])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string | number | boolean | json
  group     String   @default("general") // general | fees | legal | ai | email
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalDocument {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  locale    String   @default("cs")
  version   Int      @default(1)
  published Boolean  @default(false)
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  bodyHtml  String
  locale    String   @default("cs")
  variables String?  // JSON seznam proměnných
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Upload {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  url         String
  entityType  String?  // "auction" | "avatar" | "card" | "document"
  entityId    String?
  userId      String
  createdAt   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
}

model PriceEstimate {
  id          String   @id @default(cuid())
  cardId      String
  cardName    String
  source      String   // "ebay_api" | "cardmarket_api" | "cardbid_avg" | "ai_model"
  priceLow    Float?
  priceAvg    Float?
  priceHigh   Float?
  currency    String   @default("CZK")
  confidence  Float?   // 0-1
  metadata    String?  // JSON
  createdAt   DateTime @default(now())
}

model CardDataSource {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  type        String   // "api" | "scraper" | "manual" | "import"
  baseUrl     String?
  licenseUrl  String?
  attribution String?
  status      String   @default("active") // active | inactive | blocked
  rateLimit   Int?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Referral {
  id          String   @id @default(cuid())
  code        String   @unique
  referrerId  String
  referredId  String?
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referred    User?    @relation("Referred", fields: [referredId], references: [id])
}
